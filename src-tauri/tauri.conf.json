{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rocket-monitoring-system",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "pnpm --filter . --dir  ../src-ui dev",
    "beforeBuildCommand": "pnpm --filter . --dir ../src-ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Rocket Monitoring System",
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
